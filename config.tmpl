# Copy this file to `.env` before running the service.
# Bun automatically loads `.env`, `.env.local`, and environment-specific variants.

# PostgreSQL
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/bookmarkhub

# Server runtime
HOST=0.0.0.0
PORT=3000
RUN_MIGRATIONS=true
DEBUG=

# Protected submission API key
BOOKMARKHUB_SUBMISSION_API_KEY=replace-with-internal-submit-key
BOOKMARKHUB_REVIEW_API_KEY=replace-with-internal-review-key

# Search behavior
BOOKMARKHUB_PAGE_SIZE=24
BOOKMARKHUB_MAX_PAGE_SIZE=60
BOOKMARKHUB_SITE_NAME=BookmarkHub
BOOKMARKHUB_AI_SEARCH_ENABLED=false
BOOKMARKHUB_AI_ENRICHMENT_ENABLED=false
BOOKMARKHUB_AI_AUTO_APPROVE_ENABLED=false

# AI provider settings
BOOKMARKHUB_AI_PROVIDER=openai
BOOKMARKHUB_AI_MODEL=gpt-5.4-mini
BOOKMARKHUB_AI_BASE_URL=
BOOKMARKHUB_AI_API_KEY=
