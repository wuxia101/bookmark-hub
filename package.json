{
  "name": "bookmarkhub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "test": "bun test",
    "db:migrate": "bun run src/server/db/migrate.ts",
    "db:seed:bookmarks": "bun run src/server/db/seedBookmarks.ts",
    "db:sync:tag-translations": "bun run src/server/db/syncTagTranslations.ts",
    "db:sync:site-aliases": "bun run src/server/db/syncSiteAliases.ts"
  },
  "dependencies": {
    "bun-plugin-tailwind": "^0.1.2",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0"
  },
  "module": "src/index.ts",
  "peerDependencies": {
    "typescript": "^5"
  }
}
